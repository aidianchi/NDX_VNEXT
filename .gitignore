# NDX_VNEXT .gitignore
#
# Rule of thumb:
# - Keep source code, tests, docs, prompts, example configs, and plans.
# - Ignore secrets, virtual environments, caches, logs, and generated outputs.

# --- Secrets and local configuration ---
.env
.env.*
!.env.example
*.pem
*.key
*.secret
secrets/

# Local config files that may contain private keys or machine-specific paths.
config/*.local.json
config/*local*.json
launcher_prefs.json
CLAUDE.local.md

# Keep safe example configuration.
!config/*.example.json

# --- Python runtime artifacts ---
__pycache__/
*.py[cod]
*$py.class
.Python
*.so

# --- Virtual environments ---
.venv/
venv/
ENV/
env/

# --- Test and tool caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Data caches and generated market artifacts ---
data_cache/
output/

# --- Logs and temporary files ---
*.log
*.tmp
*.temp
tmp/
temp/

# --- Editor and OS files ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Local worktrees ---
.worktrees/
